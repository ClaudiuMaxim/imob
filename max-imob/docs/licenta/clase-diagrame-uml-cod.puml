@startuml
title Max Imob - Diagrama claselor de domeniu

enum UserRole {
  admin
  agent
}

enum PropertyType {
  apartament
  casa
  teren
  comercial
}

enum PropertyStatus {
  ciorna
  publicata
  vanduta
  inchiriata
}

enum PropertyOffer {
  vanzare
  inchiriere
}

enum MessageStatus {
  unread
  read
  archived
}

class User {
  +id: string
  +email: string
  -passwordHash: string
  +role: UserRole
  +name: string
  +phone: string
  +isActive: boolean
  +createdAt: Date
  +updatedAt: Date
  +isAdmin(): boolean
  +isAgent(): boolean
  +canAuthenticate(): boolean
}

class Admin {
  +listAgents(): Agent[]
  +createAgent(): Agent
  +updateAgent(): Agent
  +deactivateAgent(): Agent
}

class Agent {
  +createProperty(): Property
  +updateProperty(): Property
  +deactivateProperty(): Property
  +viewMessages(): Message[]
}

class Property {
  +id: string
  +agentId: string
  +title: string
  +description: string
  +price: number
  +city: string
  +address: string
  +propertyType: PropertyType
  +status: PropertyStatus
  +offerType: PropertyOffer
  +bedrooms: number
  +bathrooms: number
  +area: number
  +isActive: boolean
  +createdAt: string
  +updatedAt: string
  +publish(): void
  +activate(): void
  +deactivate(): void
  +addImage(): void
}

class PropertyImage {
  +id: string
  +propertyId: string
  +imageUrl: string
  +fileName: string
  +sortOrder: number
  +createdAt: Date
}

class Message {
  +id: string
  +propertyId: string
  +agentId: string
  +contactName: string
  +contactEmail: string
  +contactPhone: string
  +messageContent: string
  +status: MessageStatus
  +createdAt: string
  +updatedAt: string
  +markAsRead(): void
  +archive(): void
}

User <|-- Admin
User <|-- Agent
Agent "1" -- "0..*" Property : detine
Property "1" -- "0..*" PropertyImage : are
Property "1" -- "0..*" Message : primeste
Agent "1" -- "0..*" Message : gestioneaza

User --> UserRole
Property --> PropertyType
Property --> PropertyStatus
Property --> PropertyOffer
Message --> MessageStatus

@enduml


@startuml
title Max Imob - Diagrama claselor de servicii

class DatabasePool {
  +getPool(): Pool
}

class AuthService {
  +loginUser(input: LoginInput): LoginResult
  -findUserByEmail(email: string): StoredUser
  -createAuthToken(userId: string, role: UserRole): string
  -invalidCredentials(): LoginResult
}

class SessionService {
  +getAuthSession(request: NextRequest): AuthSession
  +requireAdmin(request: NextRequest): AuthSession
  +requireAgent(request: NextRequest): AuthSession
}

class AgentService {
  +listAgents(status: AgentStatusFilter): Agent[]
  +createAgent(input: CreateAgentInput): Agent
  +getAgentById(id: string): Agent
  +updateAgent(id: string, input: UpdateAgentInput): Agent
  +deactivateAgent(id: string): Agent
  +isUniqueViolation(error: unknown): boolean
}

class PropertyService {
  +listAgentProperties(agentId: string): Property[]
  +listPublicProperties(filters: PublicPropertyFilters): Property[]
  +createProperty(agentId: string, input: CreatePropertyInput, images: SavedPropertyImage[]): Property
  +getAgentPropertyById(agentId: string, propertyId: string): Property
  +getPublicPropertyById(propertyId: string): Property
  +updateProperty(agentId: string, propertyId: string, input: UpdatePropertyInput, images: SavedPropertyImage[]): Property
  +deactivateProperty(agentId: string, propertyId: string): Property
  +activateProperty(agentId: string, propertyId: string): Property
}

class MessageService {
  +saveMessage(propertyId: string, agentId: string, input: CreateMessageInput): Message
  +getPropertyById(propertyId: string): PropertyReference
  +getMessagesByPropertyId(propertyId: string): Message[]
  +getMessagesByAgentId(agentId: string): Message[]
  +markMessageAsRead(messageId: string): Message
}

class AuthError {
  +message: string
  +status: 401 | 403
}

AuthService --> DatabasePool
AgentService --> DatabasePool
PropertyService --> DatabasePool
MessageService --> DatabasePool
SessionService --> AuthError
AuthService ..> User
AgentService ..> Agent
PropertyService ..> Property
PropertyService ..> PropertyImage
MessageService ..> Message

@enduml


