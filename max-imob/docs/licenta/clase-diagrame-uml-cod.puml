@startuml
title Max Imob - Secventa autentificare

actor "Admin/Agent" as User
participant "Pagina Login" as LoginPage
participant "POST /api/auth/login" as LoginRoute
participant "LoginValidator" as Validator
participant "AuthService" as AuthService
database "PostgreSQL" as DB
participant "JWT + Cookie HTTP-only" as Cookie

User -> LoginPage : introduce email si parola
LoginPage -> LoginRoute : trimite cerere POST
LoginRoute -> Validator : valideaza input

alt date invalide
  Validator --> LoginRoute : eroare validare
  LoginRoute --> LoginPage : raspuns 400
else date valide
  Validator --> LoginRoute : input normalizat
  LoginRoute -> AuthService : loginUser(input)
  AuthService -> DB : cauta utilizator dupa email
  DB --> AuthService : user sau null

  alt credentiale incorecte sau cont inactiv
    AuthService --> LoginRoute : rezultat invalid
    LoginRoute --> LoginPage : raspuns 401
  else credentiale valide
    AuthService -> AuthService : verifica parola bcrypt
    AuthService -> AuthService : genereaza JWT
    AuthService --> LoginRoute : token si redirectUrl
    LoginRoute -> Cookie : seteaza auth_token
    LoginRoute --> LoginPage : raspuns 200
    LoginPage --> User : redirect catre /admin sau /agent
  end
end

@enduml


@startuml
title Max Imob - Secventa trimitere mesaj public

actor "Vizitator public" as Visitor
participant "Pagina detalii proprietate" as PropertyPage
participant "POST /api/properties/[id]/messages" as MessageRoute
participant "MessageValidator" as Validator
participant "MessageService" as MessageService
database "PostgreSQL" as DB

Visitor -> PropertyPage : completeaza formularul de contact
PropertyPage -> MessageRoute : trimite cerere POST
MessageRoute -> Validator : valideaza datele mesajului

alt date invalide
  Validator --> MessageRoute : lista erori
  MessageRoute --> PropertyPage : raspuns 400
  PropertyPage --> Visitor : afiseaza mesaj de eroare
else date valide
  Validator --> MessageRoute : input valid
  MessageRoute -> MessageService : getPropertyById(propertyId)
  MessageService -> DB : cauta proprietatea
  DB --> MessageService : proprietate si agentId

  alt proprietate inexistenta
    MessageService --> MessageRoute : nu exista proprietate
    MessageRoute --> PropertyPage : raspuns 404
  else proprietate existenta
    MessageRoute -> MessageService : saveMessage(propertyId, agentId, input)
    MessageService -> DB : insereaza mesajul
    DB --> MessageService : mesaj creat
    MessageService --> MessageRoute : mesaj salvat
    MessageRoute --> PropertyPage : raspuns 201
    PropertyPage --> Visitor : confirmare trimitere
  end
end

@enduml


@startuml
title Max Imob - Activitate creare proprietate

start
:Agentul acceseaza formularul de adaugare proprietate;
:Completeaza datele proprietatii;
:Trimite formularul catre API;

if (Agent autentificat?) then (da)
  :SessionService returneaza sesiunea;
else (nu)
  :API returneaza 401;
  stop
endif

if (Rolul este agent?) then (da)
  :Se continua procesarea;
else (nu)
  :API returneaza 403;
  stop
endif

:PropertyValidator verifica inputul;

if (Date valide?) then (da)
  :Se proceseaza imaginile incarcate;
  :PropertyService porneste tranzactia;
  :Se insereaza proprietatea;
  :Se insereaza imaginile asociate;
  :Se confirma tranzactia;
  :API returneaza proprietatea creata;
else (nu)
  :API returneaza 400 cu erori de validare;
endif

stop
@enduml


